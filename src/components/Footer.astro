	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 1rem;
		margin: 1rem 0 0.75rem;
	}

	.footer-links a {
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.95rem;
