---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="nav-shell" aria-label="Primary">
		<div class="brand">
			<a class="brand-link" href="/">
				<span class="brand-title">{SITE_TITLE}</span>
				<span class="brand-sub">地球文明0.5编年史</span>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home / 首页</HeaderLink>
			<HeaderLink href="/about">Preface / 序言</HeaderLink>
			<HeaderLink href="/volumes">Volumes / 卷</HeaderLink>
			<HeaderLink href="/books">Books / 书系</HeaderLink>
			<HeaderLink href="/blog">Archive / 文章</HeaderLink>
			<HeaderLink href="/submissions">Submissions / 投稿</HeaderLink>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(12px);
		background: rgba(255, 255, 255, 0.9);
		border-bottom: 1px solid rgba(var(--gray), 0.14);
	}

	.nav-shell {
		width: min(1100px, calc(100% - 2rem));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 0;
	}

	.brand {
		min-width: 0;
	}

	.brand-link {
		display: flex;
		flex-direction: column;
		gap: 0.12rem;
		text-decoration: none;
	}

	.brand-title {
		font-size: 1rem;
		font-weight: 700;
		color: rgb(var(--black));
		line-height: 1.1;
	}

	.brand-sub {
		font-size: 0.8rem;
		color: rgb(var(--gray));
		line-height: 1.1;
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.2rem 0.5rem;
	}

	@media (max-width: 780px) {
		.nav-shell {
			align-items: flex-start;
			flex-direction: column;
		}

		.internal-links {
			justify-content: flex-start;
		}
	}
</style>
