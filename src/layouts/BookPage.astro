---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getBookLangPath, getBookPagePath } from '../lib/books';

type BookEntry = CollectionEntry<'books'>;

type Props = BookEntry['data'] & {
	alternate?: BookEntry;
	previous?: BookEntry;
	next?: BookEntry;
};

const { title, description, lang, book, bookTitle, kind, partTitle, alternate, previous, next } =
	Astro.props;
const bookHome = getBookLangPath(book, lang);
const alternateLabel = lang === 'zh' ? 'Read in English' : '阅读中文版';
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
const kindLabel =
	kind === 'guide'
		? 'Guide'
		: kind === 'toc'
			? 'Table of Contents'
			: kind === 'preface'
				? 'Preface'
				: kind === 'chapter'
					? 'Chapter'
					: 'Book';
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={`${title} - ${bookTitle}`} description={description} />
		<style>
			main {
				padding-top: 2rem;
			}

			.book-shell {
				max-width: 900px;
				margin: 0 auto;
			}

			.book-topline {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				margin-bottom: 1rem;
				color: rgb(var(--gray));
				font-size: 0.94rem;
			}

			.book-topline a {
				text-decoration: none;
			}

			.language-switch {
				display: inline-flex;
				align-items: center;
				padding: 0.35rem 0.65rem;
				border-radius: 999px;
				border: 1px solid rgba(var(--line), 0.82);
				background: rgba(255, 255, 255, 0.72);
				text-decoration: none;
			}

			.book-paper {
				padding: 1.45rem 1.55rem 1.9rem;
				border-radius: 22px;
				border: 1px solid rgba(var(--line), 0.82);
				background: rgba(255, 255, 255, 0.8);
				box-shadow: var(--box-shadow);
			}

			.title {
				margin-bottom: 1.3rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid rgba(var(--line), 0.7);
			}

			.eyebrow {
				margin: 0 0 0.45rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			.part {
				margin: 0 0 0.45rem;
				color: rgb(var(--accent));
				font-weight: 700;
			}

			.summary {
				margin: 0.45rem 0 0;
				color: rgb(var(--gray-dark));
			}

			.book-content :global(h2) {
				margin-top: 2.25rem;
				padding-top: 1rem;
				border-top: 1px solid rgba(var(--line), 0.55);
			}

			.book-content :global(h3) {
				margin-top: 1.5rem;
			}

			.book-content :global(a) {
				text-decoration-thickness: 1px;
			}

			.chapter-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0.8rem;
				margin-top: 1.6rem;
				padding-top: 1.1rem;
				border-top: 1px solid rgba(var(--line), 0.72);
			}

			.chapter-nav a {
				display: block;
				padding: 0.8rem 0.9rem;
				border: 1px solid rgba(var(--line), 0.72);
				border-radius: 16px;
				background: rgba(255, 255, 255, 0.58);
				text-decoration: none;
			}

			.chapter-nav .next {
				text-align: right;
			}

			.chapter-nav span {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.86rem;
			}

			@media (max-width: 720px) {
				.book-paper {
					padding: 1.1rem 1rem 1.35rem;
				}

				.chapter-nav {
					grid-template-columns: 1fr;
				}

				.chapter-nav .next {
					text-align: left;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article class="book-shell">
				<div class="book-topline">
					<div>
						<a href="/books/">Books / 书系</a>
						<span aria-hidden="true"> / </span>
						<a href={bookHome}>{bookTitle}</a>
					</div>
					{alternate && <a class="language-switch" href={getBookPagePath(alternate)}>{alternateLabel}</a>}
				</div>
				<div class="book-paper">
					<div class="title">
						<p class="eyebrow">{kindLabel}</p>
						{partTitle && <p class="part">{partTitle}</p>}
						<h1>{title}</h1>
						<p class="summary">{description}</p>
					</div>
					<div class="book-content">
						<slot />
					</div>
					<div class="chapter-nav">
						{previous ? (
							<a href={getBookPagePath(previous)}>
								<span>{lang === 'zh' ? '上一篇' : 'Previous'}</span>
								{previous.data.title}
							</a>
						) : (
							<div></div>
						)}
						{next && (
							<a class="next" href={getBookPagePath(next)}>
								<span>{lang === 'zh' ? '下一篇' : 'Next'}</span>
								{next.data.title}
							</a>
						)}
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
