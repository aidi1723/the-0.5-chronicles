---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft && !post.data.unlisted)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = posts.slice(0, 6);
const featured = [
	{
		title: 'Volume I / 第一卷',
		desc: 'Digital Eve (1980–1995): the years when digital civilization formed before becoming normal life.',
		href: '/volumes/vol-1-1980-1995/',
	},
	{
		title: 'Now Records / 当下记录',
		desc: 'Field notes from the present: how AI, workflow, and ordinary work are changing right now.',
		href: '/blog/2026-03-06-now-records-issue-1/',
	},
	{
		title: 'Method / 方法',
		desc: 'How this project combines verifiable facts, lived scenes, and bilingual writing.',
		href: '/blog/01-method-volume/',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: grid;
				grid-template-columns: 1.3fr 0.9fr;
				gap: 1.25rem;
				align-items: stretch;
			}

			.panel {
				padding: 1.5rem;
				border-radius: 22px;
				border: 1px solid rgba(var(--line), 0.8);
				background: rgba(255, 255, 255, 0.76);
				box-shadow: var(--box-shadow);
			}

			.kicker {
				margin: 0 0 0.8rem;
				font-size: 0.85rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
			}

			.lede {
				font-size: 1.08rem;
				max-width: 34em;
			}

			.cta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
				margin-top: 1.2rem;
			}

			.cta a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.72rem 1rem;
				border-radius: 999px;
				border: 1px solid rgba(var(--line), 0.8);
				text-decoration: none;
				background: rgba(255, 255, 255, 0.72);
			}

			.cta .primary {
				background: rgba(var(--accent), 0.1);
				border-color: rgba(var(--accent), 0.28);
			}

			.mini-title {
				margin: 0 0 0.65rem;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
			}

			.feature-list,
			.latest-list {
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.feature-list li + li,
			.latest-list li + li {
				margin-top: 0.9rem;
			}

			.feature-list a,
			.latest-list a {
				text-decoration: none;
				color: inherit;
				display: block;
			}

			.feature-list strong,
			.latest-list strong {
				display: block;
				margin-bottom: 0.22rem;
			}

			.meta {
				color: rgb(var(--gray));
				font-size: 0.92rem;
			}

			.sections {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.25rem;
				margin-top: 1.35rem;
			}

			.note {
				margin-top: 1.25rem;
				padding: 1rem 1.1rem;
				border-left: 4px solid rgb(var(--accent));
				background: rgba(255,255,255,0.55);
				border-radius: 0 16px 16px 0;
			}

			@media (max-width: 820px) {
				.hero,
				.sections {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="panel">
					<p class="kicker">The 0.5 Chronicles / 《0.5纪元》</p>
					<h1>A living record of how ordinary life crossed from mechanical civilization into the AI age.</h1>
					<p class="lede">
						{SITE_TAGLINE} This project writes history from below: not only what changed,
						but how change entered homes, schools, offices, tools, habits, and imagination.
					</p>
					<div class="cta">
						<a class="primary" href="/volumes/">Enter the volumes / 进入卷目录</a>
						<a href="/blog/2026-03-06-volume-1-digital-eve-progress/">Read the latest volume update</a>
						<a href="/blog/">Browse all posts</a>
					</div>
					<div class="note">
						<strong>Current writing mode</strong>
						<p>
							Two lines are moving together: retrospective chapters for 1980–2045, and
							“Now Records” for the present moment inside the 0.5 era.
						</p>
					</div>
				</div>
				<div class="panel">
					<p class="mini-title">Start here</p>
					<ul class="feature-list">
						{featured.map((item) => (
							<li>
								<a href={item.href}>
									<strong>{item.title}</strong>
									<span class="meta">{item.desc}</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			</section>

			<section class="sections">
				<div class="panel">
					<p class="mini-title">What this site is doing</p>
					<ul>
						<li>Rebuilding the transition years from 1980 onward as volume-based history.</li>
						<li>Keeping bilingual Chinese / English publication for broader readability.</li>
						<li>Preserving present-day workflow changes as historical source material.</li>
					</ul>
				</div>
				<div class="panel">
					<p class="mini-title">Latest updates</p>
					<ol class="latest-list">
						{latest.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<strong>{post.data.title}</strong>
									<span class="meta">{post.data.pubDate.toLocaleDateString('en-CA')}</span>
								</a>
							</li>
						))}
					</ol>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
