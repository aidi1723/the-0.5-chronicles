---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft && !post.data.unlisted)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} · Archive`} description={SITE_DESCRIPTION} />
		<style>
			.archive-head {
				margin-bottom: 1.25rem;
			}

			.archive-head p {
				max-width: 40rem;
				color: rgb(var(--gray));
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.1rem;
			}

			.card {
				padding: 1rem;
				border-radius: 18px;
				border: 1px solid rgba(var(--line), 0.8);
				background: rgba(255, 255, 255, 0.76);
				box-shadow: var(--box-shadow);
			}

			.card a {
				text-decoration: none;
				color: inherit;
				display: block;
			}

			.card img {
				width: 100%;
				margin-bottom: 0.8rem;
			}

			.title {
				margin: 0 0 0.45rem;
				font-size: 1.2rem;
			}

			.date {
				margin: 0 0 0.55rem;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}

			.desc {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.98rem;
			}

			@media (max-width: 760px) {
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-head">
				<h1>Archive / 全部文章</h1>
				<p>
					This archive mixes volume chapters, method notes, progress reports, and “Now Records”.
					It is the working surface of an unfinished historical project.
				</p>
			</section>
			<section class="grid">
				{posts.map((post) => (
					<article class="card">
						<a href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image width={720} height={360} src={post.data.heroImage} alt="" />
							)}
							<h2 class="title">{post.data.title}</h2>
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<p class="desc">{post.data.description}</p>
						</a>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
