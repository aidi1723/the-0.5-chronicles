---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const mainVolumes = [
  {
    slug: 'vol-1-1980-1995',
    titleEn: 'Volume I (1980-1995)',
    titleZh: '第一卷（1980—1995）',
    descEn: 'From the tail of the mechanical age to the moment the internet entered the center of the age.',
    descZh: '从大机器时代的尾声，到互联网走进时代中心。',
    href: '/volumes/vol-1-1980-1995/',
    status: 'First full draft complete / 首轮完整成稿',
  },
  {
    slug: 'vol-2-1996-2010',
    titleEn: 'Volume II (1996-2010)',
    titleZh: '第二卷（1996—2010）',
    descEn: 'The internet moves from technical threshold to ordinary life, then into the pocket, the cloud, and the stream.',
    descZh: '互联网从技术门槛变成生活环境，并进一步进入口袋、云端与生活流。',
    href: '/volumes/vol-2-1996-2010/',
    status: 'Chapter line published / 章节主线已挂出',
  },
  {
    slug: 'vol-3-2011-2020',
    titleEn: 'Volume III (2011-2020)',
    titleZh: '第三卷（2011—2020）',
    descEn: 'Platforms, mobile systems, data, and algorithms begin to reorganize ordinary life at full scale.',
    descZh: '平台、移动系统、数据与算法开始全面重组普通生活。',
    href: '/volumes/vol-3-2011-2020/',
    status: 'Chapter line published / 章节主线已挂出',
  },
  {
    slug: 'vol-4-2021-2025',
    titleEn: 'Volume IV (2021-2025)',
    titleZh: '第四卷（2021—2025）',
    descEn: 'Machines begin acting less like tools and more like collaborators inside cognition, work, and coordination.',
    descZh: '机器开始越来越不像工具，而越来越像认知、工作与协作中的合作者。',
    href: '/volumes/vol-4-2021-2025/',
    status: 'Launch note and chapter line live / 启动说明与章节线已上线',
  },
];

const supportingTracks = [
  {
    slug: 'vol-open-2026-2029',
    titleEn: 'Open Volume (2026-2029)',
    titleZh: '开放卷（2026—2029）',
    descEn: 'A forward line kept intentionally open while the post-2025 period is still unfolding.',
    descZh: '2025 年之后仍在展开的现实先以开放线形式保留，而不提前收口成定稿卷。',
    href: '/volumes/vol-open-2026-2029/',
    status: 'Open working line / 开放工作线',
  },
  {
    slug: 'vol-0-1980-1995',
    titleEn: 'Legacy Draft Archive',
    titleZh: '早期草稿档案',
    descEn: 'Retained for writing history, abandoned chapter lines, and earlier framing passes.',
    descZh: '保留写作演变过程、旧章节线和更早一轮搭框架时留下的材料。',
    href: '/volumes/vol-0-1980-1995/',
    status: 'Reference only / 仅供参考',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} · Volumes`} description={SITE_DESCRIPTION} />
    <style>
      .intro {
        max-width: 46rem;
        margin-bottom: 1.4rem;
      }
      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      .section + .section {
        margin-top: 1.6rem;
      }
      .card {
        border: 1px solid rgba(var(--line), 0.8);
        border-radius: 20px;
        padding: 1.2rem 1.25rem;
        background: rgba(255,255,255,0.76);
        box-shadow: var(--box-shadow);
      }
      .card a {
        text-decoration: none;
        color: inherit;
        display:block;
      }
      .status {
        display: inline-flex;
        margin-bottom: 0.8rem;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-size: 0.85rem;
        background: rgba(var(--accent), 0.1);
        color: rgb(var(--accent-strong));
      }
      .title {
        font-weight: 700;
        margin: 0 0 0.5rem;
        font-size: 1.2rem;
      }
      .section-label {
        margin: 0 0 0.85rem;
        color: rgb(var(--gray));
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.82rem;
      }
      .meta { color: rgb(var(--gray)); margin: 0.25rem 0; line-height: 1.7; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <h1>Volumes / 卷目录</h1>
        <p>
          The project is organized as navigable volumes rather than a flat timeline. Each volume gathers
          chapter entry points, writing progress, and editorial context.
        </p>
        <p class="meta">
          项目按“卷”组织，而不是散乱时间线。每一卷都收纳章节入口、写作进度与编辑说明。
        </p>
      </section>

      <section class="section">
        <p class="section-label">Formal volumes / 正式卷</p>
        <div class="grid">
          {mainVolumes.map(v => (
            <article class="card">
              <a href={v.href}>
                <span class="status">{v.status}</span>
                <p class="title">{v.titleEn} / {v.titleZh}</p>
                <p class="meta">{v.descEn}</p>
                <p class="meta">{v.descZh}</p>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <p class="section-label">Supporting lines / 辅助线索</p>
        <div class="grid">
          {supportingTracks.map(v => (
            <article class="card">
              <a href={v.href}>
                <span class="status">{v.status}</span>
                <p class="title">{v.titleEn} / {v.titleZh}</p>
                <p class="meta">{v.descEn}</p>
                <p class="meta">{v.descZh}</p>
              </a>
            </article>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
