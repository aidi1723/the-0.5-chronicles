---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const chapters = [
  { year: 1980, title: 'The restarting years / 重新起步的年代，未来还在远处', href: '/blog/volumes/vol-1-digital-eve/1980-the-restarting-years/' },
  { year: 1981, title: 'From calculable to usable / 从算得出来到用得起来', href: '/blog/volumes/vol-0-1980-1995/1981-chapter-2-usable-computing/' },
  { year: 1982, title: 'Toolchains and standards / 工具链与标准化开端', href: '/blog/volumes/vol-0-1980-1995/1982-chapter-03-toolchain-and-standards/' },
  { year: 1983, title: 'Files and persistence / 文件与数据留存', href: '/blog/volumes/vol-0-1980-1995/1983-chapter-04-files-and-backups/' },
  { year: 1984, title: 'Training and division of labor / 训练与分工', href: '/blog/volumes/vol-0-1980-1995/1984-chapter-05-training-and-division-of-labor/' },
  { year: 1985, title: 'Interfaces and visibility / 界面与可见性', href: '/blog/volumes/vol-0-1980-1995/1985-chapter-06-interfaces-and-visibility/' },
  { year: 1986, title: 'Reliability and procurement / 可靠性与采购', href: '/blog/volumes/vol-0-1980-1995/1986-chapter-07-reliability-and-procurement/' },
  { year: 1987, title: 'Networks as idea / 网络作为想法', href: '/blog/volumes/vol-0-1980-1995/1987-chapter-08-networks-as-idea/' },
  { year: 1988, title: 'The shadow of network society / 网络社会的影子', href: '/blog/volumes/vol-1-digital-eve/1988-the-shadow-of-network-society/' },
  { year: 1989, title: 'Living on the edge of networks / 在网络边缘生活', href: '/blog/volumes/vol-1-digital-eve/1989-living-on-the-edge-of-networks/' },
  { year: 1990, title: 'The world organizes like the web / 世界开始按网页方式组织自己', href: '/blog/volumes/vol-1-digital-eve/1990-the-world-begins-to-organize-like-the-web/' },
  { year: 1991, title: 'Network as public space / 网络转向公共空间', href: '/blog/volumes/vol-1-digital-eve/1991-network-becomes-public-space/' },
  { year: 1992, title: 'Preparing to enter public view / 准备进入大众视野', href: '/blog/volumes/vol-1-digital-eve/1992-preparing-to-enter-public-view/' },
  { year: 1993, title: 'The public entrance appears / 大众入口出现', href: '/blog/volumes/vol-1-digital-eve/1993-first-public-entrance/' },
  { year: 1994, title: 'Internet becomes worth trying / 互联网开始像一件值得试试的东西', href: '/blog/volumes/vol-1-digital-eve/1994-internet-becomes-inviting/' },
  { year: 1995, title: 'Internet enters the center / 互联网走进时代中心', href: '/blog/2026-03-06-chapter-1995-internet-enters-the-center/' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${SITE_TITLE} · Volume I`}
      description="Volume I (1980–1995): from the tail of the mechanical age to the moment the internet entered the center of the age."
    />
    <style>
      .hero,
      .section {
        padding: 1.35rem 1.45rem;
        border-radius: 22px;
        border: 1px solid rgba(var(--line), 0.8);
        background: rgba(255,255,255,0.76);
        box-shadow: var(--box-shadow);
      }
      .hero + .section,
      .section + .section {
        margin-top: 1.2rem;
      }
      .eyebrow {
        margin: 0 0 0.5rem;
        color: rgb(var(--gray));
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.85rem;
      }
      .lead {
        max-width: 44rem;
      }
      .chapter-list {
        margin: 0;
        padding-left: 1.2rem;
      }
      .chapter-list li + li {
        margin-top: 0.45rem;
      }
      .chapter-list a {
        text-decoration: none;
      }
      .muted {
        color: rgb(var(--gray));
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <p class="eyebrow">Volume I / 第一卷</p>
        <h1>Digital Eve / 数字前夜</h1>
        <p class="lead">
          This volume follows the years in which digital civilization formed before it felt normal:
          when computers were still rare, interfaces were being learned, networks were only half-visible,
          and ordinary people first sensed that the future would be computational.
        </p>
        <p class="muted">
          这一卷写的是数字文明尚未成为常识之前的形成过程：机器仍稀缺，界面正在被学习，网络只露出一半身影，
          但普通人已经开始感到未来会带着“计算”的气味到来。
        </p>
      </section>

      <section class="section">
        <h2>Editorial note / 编辑说明</h2>
        <p>
          <strong>《0.5纪元》并不试图替大人物重写历史，而是想证明：平凡人同样可以为时代留下底稿。</strong>
          真正推动时代进入下一阶段的，从来不只是实验室里的突破、公司里的决策和新闻里的大事件，
          也包括无数普通人在家庭、学校、工厂、办公室与城市生活中的迟疑、学习、适应、错位与重新理解。
          我们写下这些，并不是为了把个人经验夸大成历史，而是为了让历史重新看见：一个时代究竟怎样进入普通人的生活。
        </p>
      </section>

      <section class="section">
        <h2>Included chapter entries / 已纳入章节入口</h2>
        <ol class="chapter-list">
          {chapters.map((chapter) => (
            <li>
              {chapter.href ? (
                <a href={chapter.href}>{chapter.year}: {chapter.title}</a>
              ) : (
                <span class="muted">{chapter.year}: {chapter.title}</span>
              )}
            </li>
          ))}
        </ol>
      </section>

      <section class="section">
        <h2>Companion materials / 配套材料</h2>
        <ul>
          <li><a href="/blog/2026-03-06-volume-1-completion-note/">Volume I completion note / 第一卷完成说明</a></li>
          <li><a href="/blog/2026-03-06-volume-1-digital-eve-progress/">Volume I progress update / 第一卷进度说明</a></li>
          <li><a href="/blog/2026-03-06-now-records-issue-1/">Now Records Issue 1 / 《当下记录》第一辑</a></li>
          <li><a href="/blog/01-method-volume/">Method volume / 方法卷</a></li>
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
