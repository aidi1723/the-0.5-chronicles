---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Volume I moved / 页面已迁移"
      description="Volume I has moved to the corrected 1980–1995 route."
    />
    <meta http-equiv="refresh" content="0; url=/volumes/vol-1-1980-1995/" />
    <style>
      .wrap {
        padding: 1.4rem 1.5rem;
        border-radius: 22px;
        border: 1px solid rgba(var(--line), 0.8);
        background: rgba(255,255,255,0.76);
        box-shadow: var(--box-shadow);
      }
      .muted {
        color: rgb(var(--gray));
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="wrap">
        <h1>Volume I moved / 第一卷页面已迁移</h1>
        <p>
          The corrected route for Volume I is now:
          <a href="/volumes/vol-1-1980-1995/">/volumes/vol-1-1980-1995/</a>
        </p>
        <p class="muted">
          第一卷的规范入口现已更正为：
          <a href="/volumes/vol-1-1980-1995/">/volumes/vol-1-1980-1995/</a>
        </p>
      </section>
    </main>
    <Footer />
  </body>
</html>
